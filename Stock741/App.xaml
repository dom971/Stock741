<Application x:Class="Stock741.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Stock741.Converters"
             xmlns:views="clr-namespace:Stock741.Views"
             xmlns:viewmodels="clr-namespace:Stock741.ViewModels"
             Startup="Application_Startup">
    
    <Application.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#444444"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate DataType="{x:Type viewmodels:MarqueViewModel}">
            <views:MarqueView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:MaterielViewModel}">
            <views:MaterielView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ModeleViewModel}">
            <views:ModeleView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:RequeteViewModel}">
            <views:RequeteView/>
        </DataTemplate>

    </Application.Resources>
</Application>