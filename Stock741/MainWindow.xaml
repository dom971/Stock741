<Window x:Class="Stock741.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stock741"
        Icon="stock741.ico"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menu latéral -->
        <Border Background="#2D2D2D">
            <StackPanel Margin="10">
                <TextBlock Text="Stock741"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,20,0,30"
                           HorizontalAlignment="Center"/>

                <Button Content="Marques"
                        Command="{Binding NaviguerVersCommand}"
                        CommandParameter="Marques"
                        Style="{StaticResource MenuButtonStyle}"
                        Margin="0,5"/>

                <Button Content="Matériels"
                        Command="{Binding NaviguerVersCommand}"
                        CommandParameter="Materiels"
                        Style="{StaticResource MenuButtonStyle}"
                        Margin="0,5"/>

                <Button Content="Modèles"
                        Command="{Binding NaviguerVersCommand}"
                        CommandParameter="Modeles"
                        Style="{StaticResource MenuButtonStyle}"
                        Margin="0,5"/>
                <Button Content="Requêtes"
                        Command="{Binding NaviguerVersCommand}"
                        CommandParameter="Requetes"
                        Style="{StaticResource MenuButtonStyle}"
                        Margin="0,5"/>
            </StackPanel>
        </Border>

        <!-- Zone de contenu -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding TitreVueActuelle}"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="10,10,0,5"
                       Foreground="#2D2D2D"/>

            <ContentControl Grid.Row="1"
                            Content="{Binding VueActuelle}"
                            Margin="10"/>
        </Grid>
    </Grid>
</Window>