<Window x:Class="Stock741.MarqueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion des Marques" Height="500" Width="700">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- DataGrid -->
        <DataGrid x:Name="DataGridMarques"
                  ItemsSource="{Binding Marques}"
                  SelectedItem="{Binding SelectedMarque, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn     Header="Id"          Binding="{Binding Id}"          Width="50"/>
                <DataGridTextColumn     Header="Nom"         Binding="{Binding Nom}"         Width="150"/>
                <DataGridTextColumn     Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridCheckBoxColumn Header="Actif"       Binding="{Binding Actif}"        Width="50"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Formulaire -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Nom" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Margin="0,0,0,6"
                     Text="{Binding SelectedMarque.Nom, Mode=TwoWay,
                            UpdateSourceTrigger=PropertyChanged,
                            TargetNullValue='',
                            FallbackValue=''}"/>

            <TextBlock Grid.Row="1" Text="Description" VerticalAlignment="Center"/>
            <TextBox Grid.Row="1" Grid.Column="1"
                     Text="{Binding SelectedMarque.Description, Mode=TwoWay,
                            UpdateSourceTrigger=PropertyChanged,
                            TargetNullValue='',
                            FallbackValue=''}"/>
        </Grid>

        <!-- Boutons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Nouveau"  Width="80" Margin="5" Click="BtnNouveau_Click"/>
            <Button Content="Ajouter"   Width="80" Margin="5" Click="BtnAjouter_Click"
                    IsEnabled="{Binding PeutAjouter}"/>
            <Button Content="Modifier"  Width="80" Margin="5" Click="BtnModifier_Click"
                    IsEnabled="{Binding PeutModifier}"/>
            <Button Content="Supprimer" Width="80" Margin="5" Click="BtnSupprimer_Click"
                    IsEnabled="{Binding PeutModifier}"/>

        </StackPanel>
    </Grid>
</Window>



