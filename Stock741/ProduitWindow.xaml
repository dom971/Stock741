<Window x:Class="Stock741.ProduitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stock741" Height="350" Width="400">

    <StackPanel Margin="10">
        <TextBlock Text="{Binding NombreProduits}" FontSize="16"/>
        <TextBlock Text="Nom du produit :" />
        <TextBox Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
        <TextBlock Text="Quantité :" />
        <TextBox Text="{Binding Quantite, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>        

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Ajouter" Command="{Binding AjouterProduitCommand}" Width="100" Margin="0,0,5,0"/>
            <Button Content="Supprimer" Command="{Binding SupprimerProduitCommand}" Width="100"/>
            <Button Content="Modifier"  Command="{Binding ModifierProduitCommand}"  Width="100"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Produits}" 
                  SelectedItem="{Binding ProduitSelectionne}" 
                  AutoGenerateColumns="False" Height="200">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" />
                <DataGridTextColumn Header="Quantité" Binding="{Binding Quantite}" />
            </DataGrid.Columns>
        </DataGrid>

    </StackPanel>
</Window>