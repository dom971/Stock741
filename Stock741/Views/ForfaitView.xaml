<UserControl x:Class="Stock741.Views.ForfaitView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
            <Label Content="Nom:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="200"
                     Text="{Binding NomSelectionne, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,10,0"/>
            <Label Content="Opérateur:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox Width="120"
                      ItemsSource="{Binding Operateurs}"
                      SelectedItem="{Binding OperateurSelectionne}"
                      DisplayMemberPath="Nom"
                      Margin="0,0,10,0"/>
            <CheckBox Content="Actif" IsChecked="{Binding ActifSelectionne}"
                      VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Button Content="Ajouter"   Command="{Binding AjouterForfaitCommand}"   Margin="5,0,0,0"/>
            <Button Content="Modifier"  Command="{Binding ModifierForfaitCommand}"  Margin="5,0,0,0"/>
            <Button Content="Supprimer" Command="{Binding SupprimerForfaitCommand}" Margin="5,0,0,0"/>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="{Binding ErreurGlobale}"
                   Foreground="Red"
                   FontWeight="SemiBold"
                   Margin="0,0,0,5"
                   Visibility="{Binding ErreurGlobale, Converter={StaticResource StringToVisibilityConverter}}"/>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Forfaits}"
                  AutoGenerateColumns="False"
                  SelectedItem="{Binding ForfaitSelectionne}"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id"        Binding="{Binding Id}"           Width="Auto"/>
                <DataGridTextColumn Header="Nom"       Binding="{Binding Nom}"          Width="*"/>
                <DataGridTextColumn Header="Opérateur" Binding="{Binding Operateur.Nom}" Width="Auto"/>
                <DataGridCheckBoxColumn Header="Actif" Binding="{Binding Actif}"        Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>