<UserControl x:Class="Stock741.Views.FournisseurView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
            <Label Content="Nom:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="200"
                     Text="{Binding NomSelectionne, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,10,0"/>
            <Button Content="Ajouter"    Command="{Binding AjouterFournisseurCommand}"   Margin="5,0,0,0"/>
            <Button Content="Modifier"   Command="{Binding ModifierFournisseurCommand}"  Margin="5,0,0,0"/>
            <Button Content="Supprimer"  Command="{Binding SupprimerFournisseurCommand}" Margin="5,0,0,0"/>
            <Button Content="Actualiser" Command="{Binding ActualiserCommand}"           Margin="15,0,0,0"/>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="{Binding ErreurGlobale}"
                   Foreground="Red"
                   FontWeight="SemiBold"
                   Margin="0,0,0,5"
                   Visibility="{Binding ErreurGlobale, Converter={StaticResource StringToVisibilityConverter}}"/>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Fournisseurs}"
                  AutoGenerateColumns="False"
                  SelectedItem="{Binding FournisseurSelectionne}"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id"  Binding="{Binding Id}"  Width="Auto"/>
                <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>