<Window x:Class="Stock741.Views.MarqueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Marques" Height="400" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Label Content="Nom:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="200"
                     Text="{Binding NomSelectionne, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                     Margin="0,0,10,0">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Validation.HasError" Value="True">
                                <Setter Property="Foreground" Value="Red"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <CheckBox Content="Actif" IsChecked="{Binding ActifSelectionne}" Margin="10,0,0,0"/>
            <Button Content="Ajouter" Command="{Binding AjouterMarqueCommand}" Margin="10,0,0,0"/>
            <Button Content="Modifier" Command="{Binding ModifierMarqueCommand}" Margin="10,0,0,0"/>
            <Button Content="Supprimer" Command="{Binding SupprimerMarqueCommand}" Margin="10,0,0,0"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Marques}" AutoGenerateColumns="False"
                  SelectedItem="{Binding MarqueSelectionnee}" CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Nom" Binding="{Binding Nom}"/>
                <DataGridCheckBoxColumn Header="Actif" Binding="{Binding Actif}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
    
