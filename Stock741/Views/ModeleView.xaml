<UserControl x:Class="Stock741.Views.ModeleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- Barre de saisie -->
        <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
            <Label Content="Nom:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="150"
                     Text="{Binding NomSelectionne, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,10,0"/>

            <Label Content="Marque:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox Width="120"
                      ItemsSource="{Binding Marques}"
                      SelectedItem="{Binding MarqueSelectionnee}"
                      DisplayMemberPath="Nom"
                      Margin="0,0,10,0"/>

            <Label Content="Matériel:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox Width="120"
                      ItemsSource="{Binding Materiels}"
                      SelectedItem="{Binding MaterielSelectionne}"
                      DisplayMemberPath="Nom"
                      Margin="0,0,10,0"/>

            <Label Content="Photo:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="150"
                     Text="{Binding CheminPhotoSelectionne, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,5,0"/>
            <Button Content="..." Command="{Binding ParcourirPhotoCommand}" Margin="0,0,10,0"/>

            <CheckBox Content="Actif" IsChecked="{Binding ActifSelectionne}"
                      VerticalAlignment="Center" Margin="0,0,10,0"/>

            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                <Button Content="Ajouter"    Command="{Binding AjouterModeleCommand}"   Margin="0,0,5,0"/>
                <Button Content="Modifier"   Command="{Binding ModifierModeleCommand}"  Margin="0,0,5,0"/>
                <Button Content="Supprimer"  Command="{Binding SupprimerModeleCommand}" Margin="0,0,5,0"/>
                <Button Content="Actualiser" Command="{Binding ActualiserCommand}"/>
            </StackPanel>
        </WrapPanel>

        <!-- Barre de filtre -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
            <Label Content="🔍" VerticalAlignment="Center"/>
            <Label Content="Nom:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="150"
                     Text="{Binding FiltreNom, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,10,0"/>

            <Label Content="Marque:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox Width="120"
                      ItemsSource="{Binding Marques}"
                      SelectedItem="{Binding FiltreMarque}"
                      DisplayMemberPath="Nom"
                      Margin="0,0,10,0"/>

            <Label Content="Matériel:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox Width="120"
                      ItemsSource="{Binding Materiels}"
                      SelectedItem="{Binding FiltreMateriel}"
                      DisplayMemberPath="Nom"
                      Margin="0,0,10,0"/>

            <Button Content="Réinitialiser"
                    Command="{Binding ReinitialiserFiltreCommand}"
                    Margin="5,0,0,0" Cursor="Hand"/>
        </StackPanel>

        <!-- TextBlock erreur -->
        <TextBlock Grid.Row="2"
                   Text="{Binding ErreurGlobale}"
                   Foreground="Red"
                   FontWeight="SemiBold"
                   Margin="0,0,0,5"
                   Visibility="{Binding ErreurGlobale, Converter={StaticResource StringToVisibilityConverter}}"/>

        <!-- DataGrid -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Modeles}"
                  AutoGenerateColumns="False"
                  SelectedItem="{Binding ModeleSelectionne}"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id"       Binding="{Binding Id}"           Width="Auto"/>
                <DataGridTextColumn Header="Nom"      Binding="{Binding Nom}"          Width="*"/>
                <DataGridTextColumn Header="Marque"   Binding="{Binding Marque.Nom}"   Width="Auto"/>
                <DataGridTextColumn Header="Matériel" Binding="{Binding Materiel.Nom}" Width="Auto"/>
                <DataGridTextColumn Header="Photo"    Binding="{Binding CheminPhoto}"  Width="Auto"/>
                <DataGridCheckBoxColumn Header="Actif" Binding="{Binding Actif}"       Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Image -->
        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
                   Source="{Binding ModeleSelectionne.CheminPhoto, Converter={StaticResource NomFichierToImageConverter}}"
                   Stretch="Uniform"
                   HorizontalAlignment="Left"
                   Width="200"
                   Height="180"/>

            <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Nom" Foreground="#00643E" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding ModeleSelectionne.Nom}" FontSize="14" Foreground="#535353" Margin="0,0,0,12"/>

                <TextBlock Text="Marque" Foreground="#00643E" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding ModeleSelectionne.Marque.Nom}" FontSize="14" Foreground="#535353" Margin="0,0,0,12"/>

                <TextBlock Text="Matériel" Foreground="#00643E" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding ModeleSelectionne.Materiel.Nom}" FontSize="14" Foreground="#535353" Margin="0,0,0,12"/>

                <TextBlock Text="Fiche" Foreground="#00643E" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding ModeleSelectionne.Materiel.Fiche.Nom}" FontSize="14" Foreground="#535353"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>