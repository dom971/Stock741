<Window x:Class="Stock741.Views.ProduitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion Produits" Height="450" Width="800">

    <StackPanel Margin="10">

        <!-- Nom du produit -->
        <TextBlock Text="Nom :" Margin="0,5"/>
        <TextBox Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}" />

        <!-- Quantité --><!--
        <TextBlock Text="Quantité :" Margin="0,5"/>
        <TextBox Text="{Binding Quantite, UpdateSourceTrigger=PropertyChanged}" />-->

        <!-- Boutons CRUD -->
        <StackPanel Orientation="Horizontal" Margin="0,10">
            <Button Content="Ajouter" Command="{Binding AjouterProduitCommand}" Width="100" Margin="5"/>
            <Button Content="Modifier" Command="{Binding ModifierProduitCommand}" Width="100" Margin="5"/>
            <Button Content="Supprimer" Command="{Binding SupprimerProduitCommand}" Width="100" Margin="5"/>
        </StackPanel>

        <!-- DataGrid pour afficher les produits -->
        <DataGrid ItemsSource="{Binding Produits}"
                  SelectedItem="{Binding ProduitSelectionne}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Height="250"
                  Margin="0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*" />
                <!--<DataGridTextColumn Header="Quantité" Binding="{Binding Quantite}" Width="100" />-->
            </DataGrid.Columns>
        </DataGrid>

    </StackPanel>
</Window>