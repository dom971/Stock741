<UserControl x:Class="Stock741.Views.RequeteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Zone de saisie -->
        <TextBox Grid.Row="0"
                 Text="{Binding Requete, UpdateSourceTrigger=PropertyChanged}"
                 Height="100"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="13"
                 Margin="0,0,0,5"/>

        <!-- Boutons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
            <Button Content="Exécuter"
                    Command="{Binding ExecuterRequeteCommand}"
                    Margin="0,0,10,0"
                    Width="100"/>
            <Button Content="Effacer"
                    Command="{Binding EffacerCommand}"
                    Width="100"/>
            <TextBlock Text="{Binding InfoResultat}"
                       Foreground="Green"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"/>
        </StackPanel>

        <!-- Erreur -->
        <TextBlock Grid.Row="2"
                   Text="{Binding ErreurGlobale}"
                   Foreground="Red"
                   FontWeight="SemiBold"
                   Margin="0,0,0,5"
                   Visibility="{Binding ErreurGlobale, Converter={StaticResource StringToVisibilityConverter}}"/>

        <!-- Résultats -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Resultats}"
                  AutoGenerateColumns="True"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"/>
    </Grid>
</UserControl>